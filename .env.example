# API runtime
DMS_HOST=0.0.0.0
DMS_PORT=3000
DMS_DB_PATH=./dms.db

# Security
# Required in production. Use long random values and never commit real secrets.
JWT_SECRET=change-me-to-a-long-random-access-token-secret
REFRESH_SECRET=change-me-to-a-long-random-refresh-token-secret

# Required in production. Comma-separated explicit origins; do not use *.
DMS_CORS_ORIGINS=http://localhost:5173

# Initial production bootstrap only. Required when a production database has no admin user.
# The seeded admin is forced to change this password after first login.
DMS_BOOTSTRAP_ADMIN_PASSWORD=change-me-before-first-production-start

# Desktop wrapper only. In production desktop mode CORS still uses DMS_CORS_ORIGINS.
DMS_DESKTOP=false
